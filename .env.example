# TikTok Developer App (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_REDIRECT_URI=https://your-domain.com/callback

# Nach dem ersten OAuth-Login hier eintragen (optional, sonst wird OAuth-Flow gestartet)
# TIKTOK_ACCESS_TOKEN=your_access_token
# TIKTOK_REFRESH_TOKEN=your_refresh_token

# Optional: Pexels API für kostenlose Stock-Bilder (https://www.pexels.com/api/)
# PEXELS_API_KEY=your_pexels_key

# Optional: Auf dem Raspberry Pi für schnellere Encodes kleinere Auflösung
# VIDEO_WIDTH=720
# VIDEO_HEIGHT=1280
