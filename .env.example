# TikTok Developer App (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_REDIRECT_URI=https://your-domain.com/callback

# Nach dem ersten OAuth-Login hier eintragen (optional, sonst wird OAuth-Flow gestartet)
# TIKTOK_ACCESS_TOKEN=your_access_token
# TIKTOK_REFRESH_TOKEN=your_refresh_token

# Pexels API – für Hintergrund-Videos (Natur, Landschaft etc.) – https://www.pexels.com/api/
# Mit Key sucht der Bot passende Clips und legt sie hinter den Text.
# PEXELS_API_KEY=your_pexels_key
# VIDEO_BACKGROUND_QUERY=nature landscape
# Optional: eigener Ordner mit MP4-Videos als Hintergrund (statt Pexels)
# BACKGROUND_VIDEOS_DIR=./output/backgrounds

# Optional: Auf dem Raspberry Pi für schnellere Encodes kleinere Auflösung
# VIDEO_WIDTH=720
# VIDEO_HEIGHT=1280

# Ideen-Quelle (ohne manuelles ideas.json eintragen):
# IDEA_SOURCE=trends_then_file   = zuerst Google-Trends, dann ideas.json (Standard)
# IDEA_SOURCE=trends             = nur Trends
# IDEA_SOURCE=file               = nur ideas.json
# IDEA_SOURCE=trends_then_file
# TRENDS_COUNTRY=germany
# TRENDS_CACHE_HOURS=12

# TTS – Standard: Edge (kostenlos). Besserer Klang: OpenAI (kostenpflichtig).
# TTS_ENGINE=edge
# TTS_VOICE=de-DE-KatjaNeural
# Für OpenAI: TTS_ENGINE=openai, OPENAI_API_KEY=sk-…, TTS_VOICE=nova (oder alloy, echo, fable, onyx, shimmer)
# OPENAI_API_KEY=
